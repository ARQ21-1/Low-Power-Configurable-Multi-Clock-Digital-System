####################################################################################
#########################################################
#### Section 5 : Output load ####
#########################################################
####################################################################################
set_load 0.1 [get_ports {UART_TX_O parity_error framing_error}]
####################################################################################
#########################################################
#### Section 6 : Operating Condition ####
#########################################################
